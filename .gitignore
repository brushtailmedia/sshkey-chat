# Binaries (root-only — leading slash is load-bearing; bare `sshkey-server` /
# `sshkey-ctl` would match the cmd/sshkey-server/ and cmd/sshkey-ctl/ source
# directories as well, quietly ignoring every file inside them)
/sshkey-server
/sshkey-ctl
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace
go.work
go.work.sum

# Dependency directories
vendor/

# Runtime data (never commit server data)
*.db
*.db-wal
*.db-shm
host_key
pending-keys.log
audit.log
server.log
server.log.*

# Credentials (never commit keys or service accounts)
*.p8
*.pem
firebase-sa.json
*.json.bak
.env

# Docker runtime
docker/config/host_key

# Design docs (internal working files, not checked in)
refactor_plan.md
performance_optimization.md
groups_admin.md
message_editing.md
business_edition.md

# OS
.DS_Store
Thumbs.db

# Editor/IDE
.idea/
.vscode/
*.swp
*.swo
*~
